{
  "zmod": 1,
  "name": "Game of Life Melody",
  "category": "Sequencing",
  "desc": "Conway's Game of Life sequencer, scale-locked.",
  "overview": "Conway's Game of Life drives an 8x8 melodic sequencer - gliders and blinkers become ever-shifting note patterns - and a scale block keeps every emergent note musical. Endless generative melody from a cellular automaton.",
  "blocks": [
    {
      "type": "MidiGameOfLife",
      "category": "Sequencing",
      "desc": "Conway's Game of Life MIDI sequencer: an 8x8 cell grid evolves under the B3/S23 rule; each clock step reads the next column and plays a note for every live cell (row maps to a scale degree from Root/Scale), and a full 8-step sweep advances one generation. Gliders, blinkers and still-lifes become ever-shifting melodic and harmonic patterns. Density sets the random fill when the grid (re)seeds. The MIDI-note counterpart to the GameOfLife CV block.",
      "ins": [
        "In A",
        "In B",
        "In C"
      ],
      "numIns": 3,
      "params": [
        {
          "name": "Root",
          "value": 0.0,
          "min": 0.0,
          "max": 11.0,
          "def": 0.0,
          "unit": ""
        },
        {
          "name": "Scale",
          "value": 1.0,
          "min": 0.0,
          "max": 19.0,
          "def": 1.0,
          "unit": ""
        },
        {
