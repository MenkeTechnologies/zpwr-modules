          "min": 0.0,
          "max": 11.0,
          "def": 4.0,
          "unit": ""
        },
        {
          "name": "Gate",
          "value": 0.5,
          "min": 0.0,
          "max": 2.0,
          "def": 0.5,
          "unit": ""
        },
        {
          "name": "Density",
          "value": 0.349999994039536,
          "min": 0.0,
          "max": 1.0,
          "def": 0.349999994039536,
          "unit": ""
        }
      ]
    },
    {
