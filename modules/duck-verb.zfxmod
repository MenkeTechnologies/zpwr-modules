{
  "zmod": 1,
  "name": "Duck Verb",
  "category": "Reverb",
  "desc": "Sidechain-ducked reverb that breathes with the input.",
  "overview": "A reverb that ducks out of the way while you play and blooms in the gaps, kept tidy by a following EQ. The tail never clutters the dry signal - ideal for busy vocals and lead lines.",
  "blocks": [
    {
      "type": "DuckVerb",
      "category": "Reverb",
      "desc": "Reverb whose wet signal is attenuated by an envelope follower tracking the dry input, so the tail dips while you play and swells back in the gaps. Size sets the room length and Damp the high-frequency decay, Duck sets how strongly the dry level suppresses the wet, and Mix blends the ducked reverb against the dry signal. Keeps the reverb from washing out a busy performance while preserving the tail between phrases.",
      "ins": [
        "Audio"
      ],
      "numIns": 1,
      "params": [
        {
          "name": "Size",
          "value": 0.600000023841858,
          "min": 0.0,
          "max": 1.0,
          "def": 0.600000023841858,
          "unit": ""
        },
        {
